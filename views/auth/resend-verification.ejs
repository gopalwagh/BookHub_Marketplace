<%- include("../partials/head") %>
</head>
<body class="bg-gray-100">
  <%- include("../partials/navbar") %>
  <div class="flex justify-center items-center min-h-screen">
    <div class="bg-white p-8 rounded shadow-md w-96">  
      <h2 class="text-2xl font-bold mb-6 text-center">
        Verification Email
      </h2>
      <% if (message) { %>
        <div class="bg-red-200 text-red-800 p-3 rounded mb-4 text-center">
          <%= message %>
        </div>
      <% } %>
      <form action="/resend-verification" method="POST">
        <input
          type="email"
          name="email"
          placeholder="Enter your email"
          required
          class="w-full mb-4 p-2 border rounded focus:outline-none focus:ring-2 focus:ring-blue-400"
        />
        <button
          class="bg-blue-500 text-white w-full p-2 rounded hover:bg-blue-600 transition">
          Send Verification Email
        </button>
      </form>
    </div>
  </div>
</body>
</html>