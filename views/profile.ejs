<%- include("./partials/head") %>
<%- include("./partials/navbar", { user: user }) %>

<div class="max-w-6xl mx-auto mt-12 px-6">

  <!-- Header -->
  <div class="flex items-center justify-between mb-8">
    <h2 class="text-2xl font-semibold text-gray-800">
      Edit Profile
    </h2>

    <a href="/profile" class="text-sm text-gray-500 hover:text-gray-800 transition">
      ← Back
    </a>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

    <!-- LEFT SIDE (FORM) -->
    <div class="lg:col-span-2 space-y-6">

      <!-- Profile Info Card -->
      <div class="bg-white border border-gray-200 rounded-xl p-6">

        <h3 class="text-lg font-medium text-gray-700 mb-4">
          Personal Information
        </h3>

        <form action="/profile" method="POST" class="space-y-5">

          <!-- Name + Email -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="text-xs text-gray-500">Name</label>
              <input type="text" value="<%= userData.firstName %>" disabled
                class="w-full mt-1 border-b border-gray-300 bg-transparent py-2 text-gray-400 focus:outline-none">
            </div>

            <div>
              <label class="text-xs text-gray-500">Email</label>
              <input type="email" value="<%= userData.email %>" disabled
                class="w-full mt-1 border-b border-gray-300 bg-transparent py-2 text-gray-400 focus:outline-none">
            </div>
          </div>

          <!-- Phone -->
          <div>
            <label class="text-xs text-gray-500">Phone</label>
            <input type="text" name="phone" value="<%= userData.phone || '' %>"
              class="w-full mt-1 border-b border-gray-300 py-2 focus:border-gray-900 focus:outline-none transition">
          </div>

          <!-- Address -->
          <div>
            <label class="text-xs text-gray-500">Address</label>
            <textarea name="address"
              class="w-full mt-1 border-b border-gray-300 py-2 focus:border-gray-900 focus:outline-none transition resize-none"><%= userData.address || '' %></textarea>
          </div>

          <!-- City + Pincode -->
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-xs text-gray-500">City</label>
              <input type="text" name="city" value="<%= userData.city || '' %>"
                class="w-full mt-1 border-b border-gray-300 py-2 focus:border-gray-900 focus:outline-none transition">
            </div>

            <div>
              <label class="text-xs text-gray-500">Pincode</label>
              <input type="text" name="pincode" value="<%= userData.pincode || '' %>"
                class="w-full mt-1 border-b border-gray-300 py-2 focus:border-gray-900 focus:outline-none transition">
            </div>
          </div>

          <!-- Info -->
          <p class="font-bold text-green-500 text-sm">
            <%= user.role === "host" 
              ? "* Used for order handling & communication." 
              : "* Used for delivery and contact." %>
          </p>

          <!-- Submit -->
          <button
            class="mt-4 bg-gray-900 text-white px-6 py-2 rounded-lg text-sm hover:bg-gray-800 transition">
            Save Changes
          </button>

        </form>
      </div>

    </div>

    <!-- RIGHT SIDE (TIPS PANEL) -->
    <div class="space-y-6">
      <!-- Errors -->
      <% if (errors.length > 0) { %>
        <div class="bg-white border border-gray-200 rounded-xl p-5 text-sm text-red-600">
          <% errors.forEach(err => { %>
            <p>• <%= err.msg %></p>
          <% }) %>
        </div>
      <% } else { %>
        <!-- Success Popup -->
        <div id="successPopup" 
            class="border border-gray-200 bg-green-500 text-white px-4 py-2 rounded shadow-lg">
            ✅ Changes added successfully!
        </div>
        
      <% } %>
      <div class="bg-white border border-gray-200 rounded-xl p-5">
        <h3 class="text-sm font-semibold text-gray-700 mb-3">
          Form Tips
        </h3>

        <ul class="space-y-3 text-sm text-gray-500">
          <li>✔ Keep your details accurate</li>
          <li>✔ Use a valid phone number</li>
          <li>✔ Address should be complete</li>
          <li>✔ Helps in faster delivery</li>
        </ul>
      </div>

      <!-- Optional subtle card -->
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-5 text-sm text-gray-500">
        Your profile helps personalize your experience.
      </div>
    </div>
  </div>
</div>
<script>     
    setTimeout(() => {
     const popup = document.getElementById("successPopup");
        if (popup) popup.style.display = "none";
    }, 3000);
</script>