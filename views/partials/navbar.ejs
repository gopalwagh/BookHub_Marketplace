<nav id="navbar"
     class="fixed top-0 left-0 w-full bg-gradient-to-r from-indigo-500 via-blue-500 to-purple-500 p-[1px] shadow-xl z-50 transition-transform duration-300">

  <!-- Glass Layer -->
  <div class="bg-white/80 backdrop-blur-xl px-6 py-3 flex justify-between items-center rounded-b-2xl">

    <!-- Logo -->
    <h1 class="text-xl md:text-2xl font-extrabold flex items-center gap-2 cursor-pointer group">
      <span class="text-2xl group-hover:rotate-12 transition duration-300">📚</span>
      <span class="bg-gradient-to-r from-indigo-600 to-purple-600 text-transparent bg-clip-text">
        BookHub
      </span>
    </h1>

    <!-- Hamburger -->
    <button id="menuBtn" class="md:hidden text-2xl">
      ☰
    </button>

    <!-- Links -->
    <div id="menu"
         class="hidden md:flex items-center gap-6 absolute md:static top-full left-0 w-full md:w-auto bg-white md:bg-transparent p-6 md:p-0 shadow-md md:shadow-none">

      <% if (!user) { %>

        <a href="/login" class="nav-item block md:inline">Login</a>

        <a href="/signup"
           class="block md:inline px-5 py-2 mt-2 md:mt-0 rounded-full bg-gradient-to-r from-indigo-500 to-purple-500 text-white font-semibold shadow hover:scale-105 transition">
          Sign Up
        </a>

      <% } else if (user.role === "user") { %>

        <a href="/user/home" class="nav-item block md:inline">Home</a>
        <a href="/user/books" class="nav-item block md:inline">Browse</a>
        <a href="/user/cart" class="nav-item block md:inline">Cart</a>
        <a href="/user/orders" class="nav-item block md:inline">Orders</a>

        <a href="/profile"
          class="nav-item block md:inline">
          <span class="font-medium">Profile</span>
        </a>
        <a href="/login"
           class="mt-2 md:mt-0 px-4 py-2 rounded-full bg-red-500 text-white hover:bg-red-600 transition">
          Logout
        </a>

      <% } else if (user.role === "host") { %>

        <a href="/host/dashboard" class="nav-item block md:inline">Dashboard</a>
        <a href="/host/books" class="nav-item block md:inline">My Books</a>
        <a href="/host/add-book" class="nav-item block md:inline">Add Book</a>
        <a href="/host/orders" class="nav-item block md:inline">Orders</a>
        <a href="/profile"
          class="nav-item block md:inline">
          <span class="font-medium">Profile</span>
        </a>

        <a href="/login"
           class="mt-2 md:mt-0 px-4 py-2 rounded-full bg-red-500 text-white hover:bg-red-600 transition">
          Logout
        </a>

      <% } %>
    </div>
  </div>
</nav>

<!-- Spacer to avoid content jump -->
<div class="h-20"></div>

<style>
  .nav-item {
    position: relative;
    font-weight: 500;
    color: #374151;
    transition: 0.3s;
  }

  .nav-item::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 0%;
    height: 2px;
    background: linear-gradient(to right, #6366f1, #a855f7);
    transition: 0.3s;
  }

  .nav-item:hover {
    color: #4f46e5;
  }

  .nav-item:hover::after {
    width: 100%;
  }
</style>
<script src="/js/navbar.js"></script>