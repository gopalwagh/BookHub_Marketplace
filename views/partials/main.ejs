<main class="max-w-6xl mx-auto px-6 py-12">

  <!-- Hero Section -->
  <section class="text-center mb-16 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-xl p-10 shadow-lg animate-fadeIn">
    <h1 class="text-4xl font-bold text-gray-800 mb-4 transition">
      Welcome to BookManager 📚
    </h1>
    <p class="text-gray-600 max-w-2xl mx-auto">
      A simple platform where book lovers can explore books and book-store owners
      can easily manage and sell their collections.
    </p>

    <div class="mt-6 flex justify-center gap-4">
      <a href="/signup"
         class="bg-blue-600 text-white px-6 py-2 rounded-lg shadow-md hover:bg-blue-700 hover:scale-105 transition transform duration-300">
        Get Started
      </a>
      <a href="/user/books"
         class="border border-blue-600 text-blue-600 px-6 py-2 rounded-lg shadow-md hover:bg-blue-50 hover:scale-105 transition transform duration-300">
        Browse Books
      </a>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="grid md:grid-cols-3 gap-6 mb-16 text-center">
    <div class="bg-white shadow-md rounded-xl p-6 hover:shadow-xl transition transform hover:-translate-y-2 animate-fadeIn">
      <h2 class="text-3xl font-bold text-blue-600"><%= totalStores %>+</h2>
      <p class="text-gray-600 mt-2">Book Stores Registered</p>
    </div>
    <div class="bg-white shadow-md rounded-xl p-6 hover:shadow-xl transition transform hover:-translate-y-2 animate-fadeIn delay-200">
      <h2 class="text-3xl font-bold text-blue-600"><%= totalBooks %>+</h2>
      <p class="text-gray-600 mt-2">Books Available</p>
    </div>
    <div class="bg-white shadow-md rounded-xl p-6 hover:shadow-xl transition transform hover:-translate-y-2 animate-fadeIn delay-500">
      <h2 class="text-3xl font-bold text-blue-600"><%= totalUsers %>+</h2>
      <p class="text-gray-600 mt-2">Active Users</p>
    </div>
  </section>

  <!-- Owners Section -->
  <section class="mb-16 animate-fadeIn">
    <h2 class="text-2xl font-semibold text-gray-800 mb-6 text-center">
      For Book Store Owners (Hosts)
    </h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-gray-50 p-6 rounded-xl shadow-sm hover:bg-blue-50 transition transform hover:scale-105">
        <h3 class="font-semibold text-lg mb-2">Manage Inventory</h3>
        <p class="text-gray-600 text-sm">Easily add, edit, and manage your book collections in one place.</p>
      </div>
      <div class="bg-gray-50 p-6 rounded-xl shadow-sm hover:bg-blue-50 transition transform hover:scale-105">
        <h3 class="font-semibold text-lg mb-2">Sell Books Online</h3>
        <p class="text-gray-600 text-sm">Reach more readers by listing your books on the platform.</p>
      </div>
      <div class="bg-gray-50 p-6 rounded-xl shadow-sm hover:bg-blue-50 transition transform hover:scale-105">
        <h3 class="font-semibold text-lg mb-2">Track Sales</h3>
        <p class="text-gray-600 text-sm">Monitor your store performance and manage orders easily.</p>
      </div>
    </div>
  </section>

  <!-- Users Section -->
  <section class="animate-fadeIn">
    <h2 class="text-2xl font-semibold text-gray-800 mb-6 text-center">
      For Readers & Users
    </h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-gray-50 p-6 rounded-xl shadow-sm hover:bg-green-50 transition transform hover:scale-105">
        <h3 class="font-semibold text-lg mb-2">Discover Books</h3>
        <p class="text-gray-600 text-sm">Explore thousands of books from different stores.</p>
      </div>
      <div class="bg-gray-50 p-6 rounded-xl shadow-sm hover:bg-green-50 transition transform hover:scale-105">
        <h3 class="font-semibold text-lg mb-2">Easy Search</h3>
        <p class="text-gray-600 text-sm">Quickly find books by title, author, or category.</p>
      </div>
      <div class="bg-gray-50 p-6 rounded-xl shadow-sm hover:bg-green-50 transition transform hover:scale-105">
        <h3 class="font-semibold text-lg mb-2">Buy from Local Stores</h3>
        <p class="text-gray-600 text-sm">Support local bookstores while finding your next great read.</p>
      </div>
    </div>
  </section>
</main>