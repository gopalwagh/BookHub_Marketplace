<%- include("../../partials/head") %>

<body class="bg-gray-100 min-h-screen">

<%- include("../../partials/navbar", { user: user }) %>
<div id="customAlert" 
  class="fixed top-5 right-5 hidden px-4 py-3 rounded-lg shadow-lg text-white text-sm z-50">
</div>
<div class="flex items-center justify-center py-12 px-4">
  <div class="w-full max-w-lg bg-white rounded-xl shadow-md p-8">
    <h2 class="text-2xl font-semibold text-gray-800 mb-6 text-center">
      📚 Add New Book
    </h2>
    <form action="/host/add-book" method="POST" enctype="multipart/form-data" class="space-y-5">
      <!-- Title -->
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">Title</label>
        <div class="flex gap-2">
          <input 
            id="title"
            type="text" 
            name="title" 
            required
            placeholder="Enter book title"
            class="w-full border border-gray-300 p-2.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400">
          <button id="auto" type="button" onclick="fetchBookData()" 
            class="bg-gray-800 text-white px-3 rounded-lg text-sm">
            Auto
          </button>
        </div>
      </div>
      <!-- Author -->
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">Author</label>
        <input
          id="author" 
          type="text" 
          name="author" 
          required
          placeholder="Enter author name"
          class="w-full border border-gray-300 p-2.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">Description</label>
        <textarea 
          id="description"
          name="description"
          rows="3"
          placeholder="Book description"
          class="w-full border border-gray-300 p-2.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">
          Categories (comma separated)
        </label>

        <input 
          type="text" 
          id="categories"
          name="categories"
          placeholder="e.g. fiction, romance, thriller"
          class="w-full border border-gray-300 p-2.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400">
      </div>
      <!-- Price -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-600 mb-1">Price</label>
          <input 
            type="number" 
            name="price" 
            required 
            class="w-full border p-2.5 rounded-lg">
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-600 mb-1">Stock</label>
          <input 
            type="number"
            name="stock"
            required 
            class="w-full border p-2.5 rounded-lg">
        </div>
      </div>
      <!-- Photo -->
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">Book Photo</label>
        <input 
          type="file" 
          name="photo" 
          accept="image/*" 
          required
          class="w-full border border-gray-300 p-2 rounded-lg bg-gray-50">
      </div>
      <!-- Button -->
      <button 
        type="submit"
        class="w-full bg-blue-500 text-white py-2.5 rounded-lg font-medium hover:bg-blue-600 transition duration-200">
        Add Book
      </button>
    </form>
  </div>
</div>
</body>
<script src="/js/add-book.js"></script>
<%- include("../../partials/footer") %>