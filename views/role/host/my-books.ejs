<%- include("../../partials/head") %>

<body class="bg-gradient-to-br from-gray-50 to-gray-100 min-h-screen">

  <%- include("../../partials/navbar", { user: user }) %>

  <div class="max-w-7xl mx-auto px-6 py-10">

    <!-- Header Section -->
    <div class="flex flex-col md:flex-row items-center gap-4 mb-10">
      <h1 class="text-4xl font-extrabold text-gray-800 flex-1 tracking-tight">
        📚 My Books
      </h1>

      <!-- Search -->
      <input
        id="searchInput"
        type="text"
        placeholder="🔍 Search by title or author..."
        class="w-full md:w-64 border border-gray-200 bg-white/70 backdrop-blur-md p-3 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-400 transition">

      <!-- Filter -->
      <select
        id="stockFilter"
        class="w-full md:w-40 border border-gray-200 bg-white/70 backdrop-blur-md p-3 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-400 transition">
        <option value="all">📦 All Books</option>
        <option value="low">⚠️ Low Stock</option>
        <option value="out">❌ Out Of Stock</option>
      </select>

      <!-- Sort -->
      <select onchange="changeSort(this.value)"
        id="sortBooks"
        class="w-full md:w-44 border border-gray-200 bg-white/70 backdrop-blur-md p-3 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-400 transition">
        <option value="">↕️ Sort</option>
        <option value="priceLow" <%= sortOption === "priceLow" ? "selected" : "" %>>
          💰 Price Low → High
        </option>
        <option value="priceHigh" <%= sortOption === "priceHigh" ? "selected" : "" %>>
          💸 Price High → Low
        </option>
        <option value="nameAZ" <%= sortOption === "nameAZ" ? "selected" : "" %>>
          🔤 Name A → Z
        </option>
        <option value="nameZA" <%= sortOption === "nameZA" ? "selected" : "" %>>
          🔡 Name Z → A
        </option>
      </select>
    </div>

    <!-- Books Grid -->
    <div
      id="booksContainer"
      class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">

      <% books.forEach(book => { %>
        <div
          class="book-card bg-white/80 backdrop-blur-lg border border-gray-200 rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition duration-300 transform hover:-translate-y-2"
          data-title="<%= book.title.toLowerCase() %>"
          data-author="<%= book.author.toLowerCase() %>"
          data-price="<%= book.price %>"
          data-stock="<%= book.stock %>">

          <!-- Image -->
          <div class="overflow-hidden">
            <img
              src="<%= book.photoUrl %>"
              class="w-full h-48 object-cover transition-transform duration-300 hover:scale-110">
          </div>

          <div class="p-5">
            <!-- Title -->
            <h2 class="text-lg font-bold text-gray-800 truncate">
              <%= book.title %>
            </h2>

            <p class="text-sm text-gray-500 mb-2">
              by <%= book.author %>
            </p>

            <!-- Price -->
            <p class="text-lg font-semibold text-blue-600 mb-3">
              ₹<%= book.price %>
            </p>

            <!-- Stock Badge -->
            <% if(book.stock === 0){ %>
              <span class="inline-block bg-red-100 text-red-600 px-3 py-1 rounded-full text-xs font-medium">
                ❌ Out of Stock
              </span>
            <% } else if(book.stock < 5){ %>
              <span class="inline-block bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-xs font-medium">
                ⚠️ Low Stock (<%= book.stock %>)
              </span>
            <% } else { %>
              <span class="inline-block bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-medium">
                ✅ In Stock (<%= book.stock %>)
              </span>
            <% } %>

            <!-- Buttons -->
            <div class="flex justify-between mt-5 gap-2">
              <a
                href="/host/edit-book/<%= book._id %>"
                class="flex-1 text-center bg-gradient-to-r from-blue-500 to-blue-600 text-white px-3 py-2 rounded-lg hover:scale-105 hover:shadow-md transition">
                ✏️ Edit
              </a>

              <button
                onclick="openDeleteModal('<%= book._id %>')"
                class="flex-1 bg-gradient-to-r from-red-500 to-red-600 text-white px-3 py-2 rounded-lg hover:scale-105 hover:shadow-md transition">
                🗑 Delete
              </button>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <!-- No Results Popup -->
  <div id="noResultsMessage" 
    class="hidden mx-auto mt-10 max-w-md text-center bg-white/80 backdrop-blur-md border border-gray-200 rounded-2xl p-6 shadow-lg">
    <p class="text-lg font-semibold text-gray-700 mb-4">
      ❌ No books found in stock
    </p>
    <button
      onclick="closeNoResultsMessage()"
      class="px-6 py-2 bg-gradient-to-r from-blue-500 to-blue-600 text-white rounded-lg hover:scale-105 transition shadow-sm">
      Okay
    </button>
  </div>

  <!-- Pagination -->
  <div class="flex justify-center mt-12">
    <%- include("../../partials/pagiNation") %>
  </div>

  <!-- Delete Modal -->
  <%- include("../../partials/deleteModal") %>

</body>

<script src="/js/my-books.js"></script>

<%- include("../../partials/footer") %>