<%- include("../partials/head") %>

<body class="bg-gray-100 min-h-screen">
   <%- include("../partials/navbar-host") %>
   <div class="max-w-6xl mx-auto p-6">

      <!-- Welcome Section -->
      <div class="mb-8">
         <h1 class="text-3xl font-bold text-gray-800">
            Welcome, <span class="text-blue-600"><%= user.name %></span> 👋
         </h1>
         <p class="text-gray-500 mt-1">
            Manage your bookstore inventory and monitor stock levels.
         </p>
      </div>

      <!-- Dashboard Cards -->
      <div class="grid md:grid-cols-4 gap-6 mb-10">
         <div class="bg-blue-500 text-white p-6 rounded-xl shadow-md hover:scale-105 transition">
            <h2 class="text-lg font-semibold">📚 Total Books</h2>
            <p class="text-4xl font-bold mt-2"><%= totalBooks %></p>
         </div>
         <div class="bg-green-500 text-white p-6 rounded-xl shadow-md hover:scale-105 transition">
            <h2 class="text-lg font-semibold">💰 Inventory Value</h2>
            <p class="text-4xl font-bold mt-2">₹ <%= totalIntventoryValue.toLocaleString() %></p>
         </div>
         <div class="bg-purple-500 text-white p-6 rounded-xl shadow-md hover:scale-105 transition">
            <h2 class="text-lg font-semibold">👨‍💻 Total Authors</h2>
            <p class="text-4xl font-bold mt-2"><%= totalAuthors %></p>
         </div>
         <div class="bg-red-500 text-white p-6 rounded-xl shadow-md hover:scale-105 transition">
            <h2 class="text-lg font-semibold">❌ Out Of Stock</h2>
            <p class="text-4xl font-bold mt-2"><%= outOfStockBooks.length %></p>
         </div>
      </div>

      <!-- Low Stock Section -->
      <div class="bg-white rounded-xl shadow-md p-6 mb-8">
         <h2 class="text-2xl font-semibold text-yellow-600 mb-4">⚠️ Low Stock Books</h2>
         <% if(lowStockBooks.length === 0){ %>
            <p class="text-gray-500">No low stock books.</p>
         <% } %>
         <div class="space-y-3">
            <% lowStockBooks.forEach(book => { %>
               <div class="flex justify-between items-center border p-4 rounded-lg hover:bg-gray-50">
                  <span class="font-medium text-gray-700"><%= book.title %></span>
                  <span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-sm">
                     Stock: <%= book.stock %>
                  </span>
               </div>
            <% }) %>
         </div>
      </div>

      <!-- Out of Stock Section -->
      <div class="bg-white rounded-xl shadow-md p-6 mb-8">
         <h2 class="text-2xl font-semibold text-red-600 mb-4">❌ Out Of Stock Books</h2>
         <% if(outOfStockBooks.length === 0){ %>
            <p class="text-gray-500">All books are currently in stock.</p>
         <% } %>
         <div class="space-y-3">
            <% outOfStockBooks.forEach(book => { %>
               <div class="flex justify-between items-center border p-4 rounded-lg hover:bg-gray-50">
                  <span class="font-medium text-gray-700"><%= book.title %></span>
                  <span class="bg-red-100 text-red-600 px-3 py-1 rounded-full text-sm">Out of Stock</span>
               </div>
            <% }) %>
         </div>
      </div>

      <!-- Recently Added Books -->
      <div class="bg-white rounded-xl shadow-md p-6">
         <h2 class="text-2xl font-semibold text-blue-600 mb-4">📚 Recently Added Books</h2>
         <% if(recentBooks.length === 0){ %>
            <p class="text-gray-500">No recent books added.</p>
         <% } %>
         <ul class="divide-y divide-gray-200">
            <% recentBooks.forEach(book => { %>
               <li class="flex justify-between items-center py-3">
                  <span class="font-medium text-gray-700">
                     <%= book.title %> — <%= book.author %>
                  </span>
                  <span class="text-gray-500">₹<%= book.price %></span>
               </li>
            <% }) %>
         </ul>
         <div class="mt-6 flex justify-end">
            <a href="/host/books"
               class="inline-block bg-blue-600 text-white font-semibold px-6 py-3 rounded-lg shadow-md hover:bg-blue-700 hover:scale-105 transition">
               📖 View All My Books
            </a>
         </div>
      </div>
   </div>
</body>

<%- include("../partials/footer") %>