<%- include("../partials/head") %>
</head>
<body class="bg-gray-50 font-sans">
   <%- include("../partials/navbar-user") %>
  <!-- Hero Section -->
  <div class="text-center mt-20 bg-gradient-to-r from-blue-50 to-indigo-100 py-16 rounded-xl shadow-lg max-w-4xl mx-auto">
    <h1 class="text-5xl font-extrabold text-gray-900 tracking-tight">
      Welcome, <%= user.name %> 👋
    </h1>

    <p class="mt-6 text-lg text-gray-600">
      Discover and buy your favorite books easily
    </p>

    <a href="/user/books" 
       class="inline-block mt-8 bg-gradient-to-r from-blue-500 to-indigo-600 text-white px-8 py-3 rounded-full shadow-md hover:scale-105 transform transition duration-300">
      Browse Books
    </a>
  </div>

  <!-- Quick Actions -->
  <div class="flex justify-center gap-8 mt-16">
    <a href="/user/cart" 
       class="bg-white shadow-lg px-8 py-6 rounded-xl hover:shadow-2xl hover:-translate-y-1 transform transition duration-300 flex items-center gap-2">
      🛒 <span class="font-semibold text-gray-700">View Cart</span>
    </a>

    <a href="/user/orders" 
       class="bg-white shadow-lg px-8 py-6 rounded-xl hover:shadow-2xl hover:-translate-y-1 transform transition duration-300 flex items-center gap-2">
      📦 <span class="font-semibold text-gray-700">Your Orders</span>
    </a>
  </div>

  <!-- Footer Message -->
  <p class="text-center mt-16 text-gray-500 italic text-lg">
    📚 Keep learning. Keep growing.
  </p>

  <%- include("../partials/footer") %>
</body>
</html>