<%- include("../partials/head") %>

<body class="bg-gray-100">

<%- include("../partials/navbar-host") %>

<main class="flex-grow px-4 py-12 flex justify-center">
  <div class="w-full max-w-5xl bg-white rounded-2xl shadow-xl overflow-hidden">
    <!-- Header -->
    <div class="bg-gradient-to-r from-indigo-600 to-purple-600 p-6">
      <h2 class="text-3xl font-bold text-white text-center">
        ✏️ Edit Book Details
      </h2>
    </div>
    <!-- Content Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 p-10 items-start">
    <!-- LEFT SIDE FORM -->
      <form action="/host/edit-book/<%= book._id %>" method="POST" class="space-y-6">
        <!-- Title -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Book Title</label>
          <input
            type="text"
            name="title"
            value="<%= book.title %>"
            class="w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition"/>
        </div>

        <!-- Author -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Author Name</label>
          <input
            type="text"
            name="author"
            value="<%= book.author %>"
            class="w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition"/>
        </div>
        <!-- Price -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Price (₹)</label>
          <input
            type="number"
            name="price"
            value="<%= book.price %>"
            class="w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition"/>
        </div>
        <!-- Stock -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Available Stock</label>
          <input
            type="number"
            name="stock"
            value="<%= book.stock %>"
            class="w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition"/>
        </div>
        <!-- BUTTON -->
        <button
          type="submit"
          class="w-full bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold py-3 rounded-lg shadow-lg hover:scale-105 hover:shadow-xl transition">
          Update Book
        </button>
      </form>
      <!-- RIGHT SIDE IMAGE -->
      <div class="flex flex-col items-center justify-start text-center">
        <h3 class="text-lg font-semibold text-gray-700 mb-4">Book Preview</h3>
        <div class="bg-gray-50 p-4 rounded-xl shadow-inner">
          <img
            src="<%= book.photoUrl || '/images/default-book.png' %>"
            alt="Book Cover"
            class="w-60 h-80 object-cover rounded-lg shadow-md hover:scale-105 transition"/>
        </div>
        <p class="text-sm text-gray-500 mt-4">Preview of the current book cover</p>
      </div>
    </div>
  </div>
</main>

<%- include("../partials/footer") %>