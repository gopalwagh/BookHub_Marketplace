<%- include("../../partials/head") %>
</head>

<body class="bg-gradient-to-br from-gray-50 to-gray-100 font-sans min-h-screen">

  <%- include("../../partials/navbar", { user: user }) %>

  <!-- Hero Section -->
  <div class="relative text-center mt-20 max-w-5xl mx-auto px-6">

    <!-- Glass Card -->
    <div class="bg-white/80 backdrop-blur-xl border border-gray-200 py-16 px-8 rounded-3xl shadow-xl">

      <h1 class="text-5xl font-extrabold text-gray-900 tracking-tight">
        Welcome, <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-indigo-600">
          <%= user.name %>
        </span> 👋
      </h1>

      <p class="mt-6 text-lg text-gray-600 max-w-xl mx-auto">
        Discover, explore, and buy your favorite books with a smooth and modern experience.
      </p>

      <a href="/user/books" 
         class="inline-block mt-10 bg-gradient-to-r from-blue-500 to-indigo-600 text-white px-10 py-3 rounded-full shadow-lg hover:scale-105 hover:shadow-xl transform transition duration-300">
        📚 Browse Books
      </a>

    </div>

    <!-- Decorative Blur Elements -->
    <div class="absolute -top-10 -left-10 w-40 h-40 bg-blue-200 rounded-full blur-3xl opacity-30"></div>
    <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-indigo-200 rounded-full blur-3xl opacity-30"></div>

  </div>

  <!-- Quick Actions -->
  <div class="flex flex-col md:flex-row justify-center items-center gap-8 mt-20 px-6">

    <!-- Cart -->
    <a href="/user/cart" 
       class="w-full md:w-64 bg-white/80 backdrop-blur-lg border border-gray-200 shadow-md px-8 py-6 rounded-2xl hover:shadow-2xl hover:-translate-y-2 transform transition duration-300 flex items-center gap-4">
      <div class="text-3xl">🛒</div>
      <div>
        <p class="font-semibold text-gray-800 text-lg">View Cart</p>
        <p class="text-sm text-gray-500">Check your selected items</p>
      </div>
    </a>

    <!-- Orders -->
    <a href="/user/orders" 
       class="w-full md:w-64 bg-white/80 backdrop-blur-lg border border-gray-200 shadow-md px-8 py-6 rounded-2xl hover:shadow-2xl hover:-translate-y-2 transform transition duration-300 flex items-center gap-4">
      <div class="text-3xl">📦</div>
      <div>
        <p class="font-semibold text-gray-800 text-lg">Your Orders</p>
        <p class="text-sm text-gray-500">Track your purchases</p>
      </div>
    </a>

  </div>

  <!-- Footer Message -->
  <div class="text-center mt-20 mb-10">
    <p class="text-gray-500 italic text-lg">
      📚 Keep learning. Keep growing.
    </p>

    <div class="mt-4 h-1 w-24 mx-auto bg-gradient-to-r from-blue-400 to-indigo-500 rounded-full"></div>
  </div>

  <%- include("../../partials/footer") %>

</body>
</html>