<%- include("../../partials/head") %>

<body class="bg-gray-50 min-h-screen">
  <%- include("../../partials/navbar", { user: user }) %>

  <div class="max-w-6xl mx-auto mt-10 px-4">
    <h2 class="text-3xl font-bold text-center mb-6">
      📚 Browse Books
    </h2>

    <!-- 🔍 Search + Filter + Sort -->
    <form method="GET" action="/user/books" 
          class="mb-6 grid grid-cols-1 md:grid-cols-4 gap-3">
      
      <!-- Search -->
      <input 
        type="text" 
        name="search" 
        value="<%= search %>"
        placeholder="Search books..."
        class="border p-2 rounded-lg focus:ring-2 focus:ring-blue-400 outline-none">

      <!-- Category -->
      <select name="category" 
              class="border p-2 rounded-lg focus:ring-2 focus:ring-blue-400 outline-none">
        <option value="">All Categories</option>
        <option value="Fiction" <%= category === "Fiction" ? "selected" : "" %>>Fiction</option>
        <option value="Tech" <%= category === "Tech" ? "selected" : "" %>>Tech</option>
        <option value="Education" <%= category === "Education" ? "selected" : "" %>>Education</option>
      </select>

      <!-- Sort -->
      <select name="sort" 
          class="border p-2 rounded-lg focus:ring-2 focus:ring-blue-400 outline-none">
        <option value="latest" <%= sortOption === "latest" ? "selected" : "" %>>Latest</option>
        <option value="priceLow" <%= sortOption === "priceLow" ? "selected" : "" %>>Price Low → High</option>
        <option value="priceHigh" <%= sortOption === "priceHigh" ? "selected" : "" %>>Price High → Low</option>
        <option value="nameAZ" <%= sortOption === "nameAZ" ? "selected" : "" %>>Name A → Z</option>
        <option value="nameZA" <%= sortOption === "nameZA" ? "selected" : "" %>>Name Z → A</option>
      </select>

      <button class="bg-blue-500 text-white rounded-lg px-4 py-2 hover:bg-blue-600 transition">
        Apply
      </button>
    </form>

    <!-- 📦 Books -->
    <% if (books.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      <% books.forEach(book => { %>
        <div class="bg-white shadow rounded-lg overflow-hidden hover:shadow-lg transition">
          
          <!-- Fixed height for images -->
          <img 
            src="<%= book.photoUrl %>" 
            alt="<%= book.title %>"
            class="w-full h-64 object-cover">

          <div class="p-4">
            <h3 class="font-semibold text-lg truncate"><%= book.title %></h3>
            <p class="text-sm text-gray-500">by <%= book.author %></p>

            <div class="flex justify-between mt-3 text-sm">
              <span class="text-blue-600 font-bold">₹<%= book.price %></span>
              <% if (book.stock === 0) { %>
                <span class="text-red-600 font-semibold">Out of stock</span>
              <% } %>

            </div>

            <a href="/user/books/<%= book._id %>" 
              class="block mt-4 text-sm text-blue-500 hover:underline">
              View Details →
            </a>
          </div>
        </div>
      <% }) %>
    </div>
    <% } else { %>
      <!-- ❌ Empty State -->
      <div class="bg-white shadow rounded-lg p-6 text-center mt-10">
        <p class="text-gray-500 text-lg">No books found 😢</p>
      </div>
    <% } %>

    <!-- 🔢 Pagination -->
    <div class="flex justify-end mt-8 gap-3 flex-wrap">
      <% if (hasPreviousPage) { %>
        <a href="?page=<%= previousPage %>&search=<%= search %>&category=<%= category %>&sort=<%= sortOption %>" 
           class="px-4 py-2 bg-gray-300 rounded-lg hover:bg-gray-400 transition">
          Prev
        </a>
      <% } %>

      <% for (let i = 1; i <= totalPages; i++) { %>
        <a href="?page=<%= i %>&search=<%= search %>&category=<%= category %>&sort=<%= sortOption %>" 
           class="px-3 py-2 rounded-lg transition 
                  <%= currentPage === i ? 'bg-blue-500 text-white' : 'bg-gray-200 hover:bg-gray-300' %>">
          <%= i %>
        </a>
      <% } %>

      <% if (hasNextPage) { %>
        <a href="?page=<%= nextPage %>&search=<%= search %>&category=<%= category %>&sort=<%= sortOption %>" 
           class="px-4 py-2 bg-gray-300 rounded-lg hover:bg-gray-400 transition">
          Next
        </a>
      <% } %>
    </div>
  </div>
  <%- include("../../partials/footer") %>
</body>