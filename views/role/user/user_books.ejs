<%- include("../../partials/head") %>

<body class="bg-gray-50 min-h-screen">
  <%- include("../../partials/navbar", { user: user }) %>

  <div class="max-w-7xl mx-auto mt-10 px-4">
    <h2 class="text-3xl font-bold text-center mb-8">
      📚 Browse Books
    </h2>

    <div class="flex flex-col lg:flex-row gap-6">
      <!-- 🎯 LEFT SIDEBAR -->
      <div class="lg:w-1/4 bg-white p-5 rounded-xl shadow h-fit lg:sticky lg:top-20">
        <h3 class="text-lg font-semibold mb-4">Filters</h3>
        <form method="GET" action="/user/books">
          <!-- 🔍 Search -->
          <input 
            type="text" 
            name="search" 
            value="<%= search %>"
            placeholder="Search by title or author..."
            class="w-full border p-2 mb-4 rounded-lg focus:ring-2 focus:ring-blue-400 outline-none">

          <!-- 🎯 Categories -->
          <h4 class="font-medium mb-2">Categories</h4>
          <div class="space-y-2 max-h-60 overflow-y-auto mb-4 pr-1">
            <% categories.forEach(cat => { %>
              <label class="flex items-center gap-2 text-sm cursor-pointer">
                <input 
                  type="checkbox" 
                  name="categories" 
                  value="<%= cat %>"
                  <%= selectedCategories.includes(cat) ? "checked" : "" %>
                >
                <span class="hover:text-blue-500"><%= cat %></span>
              </label>
            <% }) %>
          </div>
          <!-- 🔄 Sort -->
          <h4 class="font-medium mb-2">Sort By</h4>
          <select name="sort" 
            class="w-full border p-2 rounded-lg mb-4 focus:ring-2 focus:ring-blue-400">
            <option value="latest" <%= sortOption === "latest" ? "selected" : "" %>>Latest</option>
            <option value="priceLow" <%= sortOption === "priceLow" ? "selected" : "" %>>Price Low → High</option>
            <option value="priceHigh" <%= sortOption === "priceHigh" ? "selected" : "" %>>Price High → Low</option>
            <option value="nameAZ" <%= sortOption === "nameAZ" ? "selected" : "" %>>Name A → Z</option>
            <option value="nameZA" <%= sortOption === "nameZA" ? "selected" : "" %>>Name Z → A</option>
          </select>

          <!-- 🔘 Apply -->
          <button 
            class="w-full bg-blue-500 text-white py-2 rounded-lg hover:bg-blue-600 transition">
            Apply Filters
          </button>
        </form>
      </div>

      <!-- 📚 RIGHT SIDE -->
      <div class="lg:w-3/4">
        <!-- 🔝 Top Info -->
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-semibold">
            Showing Results
          </h3>
        </div>
        <!-- 📦 BOOK GRID -->
        <% if (books.length > 0) { %>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
            <% books.forEach(book => { %>
              <div class="bg-white shadow rounded-xl overflow-hidden hover:shadow-lg transition">
                <img 
                  src="<%= book.photoUrl %>" 
                  alt="<%= book.title %>"
                  class="w-full h-56 object-cover">

                <div class="p-4">
                  <h3 class="font-semibold text-lg truncate">
                    <%= book.title %>
                  </h3>
                  <p class="text-sm text-gray-500">
                    by <%= book.author %>
                  </p>
                  <!-- 🏷️ Categories -->
                  <div class="flex flex-wrap gap-1 mt-2">
                    <% if (book.categories) { %>
                      <% book.categories.slice(0,2).forEach(c => { %>
                        <span class="text-xs bg-gray-200 px-2 py-1 rounded">
                          <%= c %>
                        </span>
                      <% }) %>
                    <% } %>
                  </div>

                  <!-- 💰 Price -->
                  <div class="flex justify-between items-center mt-3 text-sm">
                    <span class="text-blue-600 font-bold">
                      ₹<%= book.price %>
                    </span>

                    <% if (book.stock === 0) { %>
                      <span class="text-red-600 text-xs font-semibold">
                        Out of stock
                      </span>
                    <% } %>
                  </div>

                  <!-- 🔗 Details -->
                  <a href="/user/books/<%= book._id %>" 
                    class="block mt-3 text-sm text-blue-500 hover:underline">
                    View Details →
                  </a>

                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>

          <!-- ❌ EMPTY -->
          <div class="bg-white shadow rounded-xl p-10 text-center">
            <p class="text-gray-500 text-lg">
              No books found 😢
            </p>
          </div>

        <% } %>

        <!-- 🔢 PAGINATION -->
        <div class="flex justify-end mt-10 gap-2 flex-wrap">
          <% const categoryQuery = selectedCategories.map(c => `categories=${c}`).join("&"); %>
          <% if (hasPreviousPage) { %>
            <a href="?page=<%= previousPage %>&search=<%= search %>&<%= categoryQuery %>&sort=<%= sortOption %>" 
               class="px-4 py-2 bg-gray-300 rounded-lg hover:bg-gray-400">
              Prev
            </a>
          <% } %>

          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="?page=<%= i %>&search=<%= search %>&<%= categoryQuery %>&sort=<%= sortOption %>" 
               class="px-3 py-2 rounded-lg 
                      <%= currentPage === i ? 'bg-blue-500 text-white' : 'bg-gray-200 hover:bg-gray-300' %>">
              <%= i %>
            </a>
          <% } %>

          <% if (hasNextPage) { %>
            <a href="?page=<%= nextPage %>&search=<%= search %>&<%= categoryQuery %>&sort=<%= sortOption %>" 
               class="px-4 py-2 bg-gray-300 rounded-lg hover:bg-gray-400">
              Next
            </a>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <%- include("../../partials/footer") %>
</body>