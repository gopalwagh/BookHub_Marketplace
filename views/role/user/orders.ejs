<%- include("../../partials/head") %>

<body class="bg-gray-100">
<%- include("../../partials/navbar", { user: user }) %>
<div class="max-w-6xl mx-auto mt-10 px-4">

  <h2 class="text-3xl font-bold text-center mb-8">
    📦 Your Orders
  </h2>
  <% if (successMessage) { %>
    <div id="toast" class="mb-6 p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg text-center font-semibold">
      <%= successMessage %>
    </div>
  <% } %>
  <% if (orders.length > 0) { %>
    <% orders.forEach(order => { %>
      <div class="bg-white rounded-2xl shadow-md hover:shadow-xl transition duration-300 mb-8 overflow-hidden border">
        <div class="flex flex-wrap justify-between items-center bg-gradient-to-r from-blue-50 to-purple-50 px-6 py-4 border-b">
          <div class="text-sm text-gray-600">
            📅 <span class="font-medium">
              <%= new Date(order.createdAt).toLocaleDateString() %>
            </span>
          </div>
          <div class="flex items-center gap-3">
            <span class="px-3 py-1 text-xs font-semibold bg-green-100 text-green-700 rounded-full">
              <% if(order.status === "pending") { %>
                <span class="bg-yellow-100 text-yellow-700">
                  🟡 Pending
                </span>
              <% } else if(order.status === "shipped") { %>
                <span class="bg-blue-100 text-blue-700 ">
                  🔵 Shipped
                </span>
              <% } else { %>
                <span class="bg-green-100 text-green-700 ">
                  🟢 Delivered
                </span>
              <% } %>
            </span>
            <span class="text-lg font-bold text-green-600">
              ₹<%= order.totalAmount %>
            </span>
          </div>
        </div>
        <div class="divide-y">
          <% order.items.forEach(item => { %>
            <div class="flex items-center gap-5 px-6 py-4 hover:bg-gray-50 transition">
              <img 
                src="<%= item.bookId.photoUrl %>" 
                class="w-20 h-20 object-cover rounded-xl border shadow-sm">
              <div class="flex-1">
                <h3 class="font-semibold text-gray-800 text-lg">
                  <%= item.bookId.title %>
                </h3>
                <p class="text-sm text-gray-500">
                  by <%= item.bookId.author %>
                </p>
                <div class="flex items-center gap-3 mt-2">
                  <span class="px-2 py-1 text-xs bg-blue-100 text-blue-600 rounded-full">
                    Qty: <%= item.quantity %>
                  </span>
                  <span class="text-sm text-gray-400">
                    ₹<%= item.bookId.price %> each
                  </span>
                </div>
              </div>
              <div class="text-right">
                <p class="text-lg font-bold text-blue-600">
                  ₹<%= item.bookId.price * item.quantity %>
                </p>
              </div>
            </div>
          <% }) %>
        </div>
        <div class="flex justify-between items-center px-6 py-4 bg-gray-50">
          <p class="text-sm text-gray-500">
            Order ID: <%= order._id.toString().slice(-6).toUpperCase() %>
          </p>
          <p><a href="/user/<%= order._id %>/invoice"
              class="ml-4 inline-flex items-center gap-2 bg-gradient-to-r from-blue-500 to-indigo-600 
                      text-white px-4 py-2 rounded-lg shadow-md hover:from-blue-600 hover:to-indigo-700 
                      hover:shadow-lg transition-all duration-300 text-sm font-medium">
              <!-- Icon -->
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              Download Invoice
            </a>
          </p>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <!-- Empty State -->
    <div class="flex justify-center mt-24">
      <div class="bg-white shadow-xl rounded-2xl p-10 max-w-md text-center hover:shadow-2xl transition duration-300">
        <h3 class="text-2xl font-semibold text-gray-700 mb-4">
          No orders yet 😢
        </h3>
        <p class="text-gray-500 mb-6">
          Looks like you haven’t purchased any books yet.
        </p>
        <a href="/user/books" 
          class="inline-block bg-gradient-to-r from-blue-500 to-indigo-600 text-white px-8 py-3 rounded-full shadow-md hover:scale-105 transform transition duration-300">
          Browse Books
        </a>
      </div>
    </div>
  <% } %>
</div>
<script src="/js/orders.js"></script>
<%- include("../../partials/footer") %>
</body>