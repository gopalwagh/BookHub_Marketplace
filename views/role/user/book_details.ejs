<%- include("../../partials/head") %>

<body class="bg-gray-100 min-h-screen">
  <%- include("../../partials/navbar", { user: user }) %>
  <div class="max-w-6xl mx-auto mt-10 px-4">

    <!-- 📘 Main Section -->
    <div class="grid md:grid-cols-2 gap-8 bg-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition">

      <!-- 📸 Image -->
      <div class="flex items-center justify-center">
        <img 
          src="<%= book.photoUrl %>" 
          alt="<%= book.title %>"
          class="w-full h-[450px] object-contain rounded-xl shadow-md">
      </div>

      <!-- 📄 Details -->
      <div class="flex flex-col justify-between">
        <div>
          <h1 class="text-4xl font-bold mb-3 text-gray-800"><%= book.title %></h1>
          <p class="text-gray-500 mb-5 italic">by <%= book.author %></p>

          <textarea 
            class="w-full h-50 mb-3 p-3 border rounded-md text-gray-700 leading-relaxed overflow-y-auto resize-none" 
            placeholder="Enter description...">
            <%= book.description || "No description available." %>
          </textarea>

          <div class="mt-3 flex flex-wrap gap-2">
            <% if (book.categories && book.categories.length > 0) { %>
              <% book.categories.forEach(cat => { %>
                <span class="bg-gray-200 px-2 py-1 text-xs rounded">
                  <%= cat %>
                </span>
              <% }) %>
            <% } %>
          </div>

          <% if (book.stock === 0) { %>
            <span class="inline-block bg-red-100 text-red-600 px-4 py-1 rounded-full text-sm font-semibold mb-4">
              Out of stock
            </span>
          <% } %>

          <h2 class="text-3xl text-blue-600 font-bold mt-4">
            ₹<%= book.price %>
          </h2>
        </div>

        <!-- 🛒 Actions -->
        <div class="mt-8 flex gap-5">
          <form action="/user/cart/add" method="POST">
            <input type="hidden" name="bookId" value="<%= book._id %>">
            <button 
              class="flex items-center gap-2 bg-yellow-500 text-white px-6 py-3 rounded-lg hover:bg-yellow-600 transition font-semibold">
              🛒 Add to Cart
            </button>
          </form>

          <!-- <form action="/user/order/buy-now" method="POST">
            <input type="hidden" name="bookId" value="<%= book._id %>">
            <button 
              class="flex items-center gap-2 bg-green-500 text-white px-6 py-3 rounded-lg hover:bg-green-600 transition font-semibold">
              ⚡ Buy Now
            </button>
          </form> -->
        </div>
      </div>
    </div>

    <!-- 🔥 Related Books -->
   <div class="mt-16">
    <h2 class="text-2xl font-bold mb-8 text-gray-900 tracking-tight">
      You may also like this...
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <% relatedBooks.forEach(b => { %>
        <div class="group bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-2xl transition-all duration-300 overflow-hidden">
          <!-- Image Section -->
          <div class="relative bg-gradient-to-br from-gray-100 to-gray-200 p-4 flex items-center justify-center h-60">
            <!-- Image -->
            <img 
              src="<%= b.photoUrl %>" 
              alt="<%= b.title %>"
              class="max-h-full max-w-full object-contain transition duration-300 group-hover:scale-105 drop-shadow-md">
            <!-- Subtle overlay on hover -->
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition"></div>
          </div>
          <!-- Content -->
          <div class="p-5 flex flex-col justify-between h-30">
            <!-- Title -->
            <h3 class="text-sm font-semibold text-gray-800 leading-snug line-clamp-2 group-hover:text-blue-600 transition">
              <%= b.title %>
            </h3>
            <!-- Bottom section -->
            <div class="mt-4">
              <!-- Price + CTA -->
              <div class="flex items-center justify-between">
                <p class="text-lg font-bold text-gray-900">
                  ₹<%= b.price %>
                </p>
                <a href="/user/books/<%= b._id %>" 
                  class="text-xs font-semibold text-blue-600 hover:text-blue-800 transition">
                  View →
                </a>
              </div>
              <!-- Animated underline -->
              <div class="h-[2px] bg-blue-600 w-0 group-hover:w-full transition-all duration-300 mt-2"></div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>

  <%- include("../../partials/footer") %>
</body>