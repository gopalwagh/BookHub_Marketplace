<%- include("../partials/head") %>

<body class="bg-gray-50">
  <%- include("../partials/navbar-host") %>

  <div class="max-w-6xl mx-auto mt-10 px-4">
    <h2 class="text-3xl font-bold text-gray-800 mb-8 text-center">
      📚 My Book Collection
    </h2>
    <!-- Grid -->
    <div
      class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8"
    >
      <% books.forEach(book => { %>
      <div
        class="bg-white rounded-xl shadow-md hover:shadow-xl transition duration-300 overflow-hidden group"
      >
        <!-- Image -->
        <div class="overflow-hidden">
          <img
            src="/uploads/<%= book.photo %>"
            alt="<%= book.title %>"
            class="w-full h-48 object-cover group-hover:scale-105 transition duration-300"
          />
        </div>
        <!-- Details -->
        <div class="p-4">
          <h3 class="text-lg font-semibold text-gray-800 mb-1">
            <%= book.title %>
          </h3>
          <p class="text-gray-500 text-sm mb-3">
            by <%= book.author %>
          </p>
          <div class="flex justify-between items-center">
            <span
              class="bg-blue-100 text-blue-600 text-sm px-3 py-1 rounded-full font-semibold"
            >
              ₹<%= book.price %>
            </span>

            <span class="text-sm text-gray-500">
              Stock: <%= book.stock %>
            </span>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</body>

<%- include("../partials/footer") %>