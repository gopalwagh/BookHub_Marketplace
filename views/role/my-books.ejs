<%- include("../partials/head") %>

<body class="bg-gray-50">

  <%- include("../partials/navbar-host") %>

  <div class="max-w-7xl mx-auto px-6 py-10">
    <!-- Search + Filter + Sort -->
    <div class="flex flex-col md:flex-row items-center gap-4 mb-8">
      <h1 class="text-3xl font-bold text-gray-800 flex-1">
        📚 My Books
      </h1>
      <!-- Search -->
      <input
        id="searchInput"
        type="text"
        placeholder="Search by title or author..."
        class="w-full md:w-64 border border-gray-300 p-2 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400">
      <!-- Filter -->
      <select
        id="stockFilter"
        class="w-full md:w-40 border border-gray-300 p-2 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400">

        <option value="all">All Books</option>
        <option value="low">Low Stock</option>
        <option value="out">Out Of Stock</option>
      </select>
      <!-- Sort -->
      <select onchange="changeSort(this.value)"
        id="sortBooks"
        class="w-full md:w-40 border border-gray-300 p-2 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400">

        <option value="">Sort</option>
        <option value="priceLow"
          <%= sortOption === "priceLow" ? "selected" : "" %> 
          > Price Low → High
        </option>
        <option value="priceHigh"
          <%= sortOption === "priceHigh" ? "selected" : "" %> 
          > Price High → Low
        </option>
        <option value="nameAZ"
          <%= sortOption === "nameAZ" ? "selected" : "" %>
          > Name A → Z
        </option>
        <option value="nameZA"
          <%= sortOption === "nameZA" ? "selected" : "" %>
          > Name Z → A
        </option>
      </select>
    </div>
    <!-- Books Grid -->
    <div
      id="booksContainer"
      class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">

      <% books.forEach(book => { %>
        <div
          class="book-card bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition transform hover:-translate-y-1"
          data-title="<%= book.title.toLowerCase() %>"
          data-author="<%= book.author.toLowerCase() %>"
          data-price="<%= book.price %>"
          data-stock="<%= book.stock %>">
          <!-- Image -->
          <img
            src="<%= book.photoUrl %>"
            class="w-full h-48 object-cover">

          <div class="p-4">
            <!-- Title -->
            <h2 class="text-lg font-semibold text-gray-800 truncate">
              <%= book.title %>
            </h2>
            <p class="text-sm text-gray-500 mb-2">
              by <%= book.author %>
            </p>
            <!-- Price -->
            <p class="font-semibold text-blue-600 mb-2">
              ₹<%= book.price %>
            </p>
            <!-- Stock Badge -->
            <% if(book.stock === 0){ %>
              <span class="inline-block bg-red-100 text-red-600 px-3 py-1 rounded-full text-xs">
                Out of Stock
              </span>
            <% } else if(book.stock < 5){ %>
              <span class="inline-block bg-yellow-100 text-yellow-600 px-3 py-1 rounded-full text-xs">
                Low Stock (<%= book.stock %>)
              </span>
            <% } else { %>
              <span class="inline-block bg-green-100 text-green-600 px-3 py-1 rounded-full text-xs">
                In Stock ( <%= book.stock %> )
              </span>
            <% } %>
            <!-- Buttons -->
            <div class="flex justify-between mt-4">
              <a
                href="/host/edit-book/<%= book._id %>"
                class="bg-blue-500 text-white px-3 py-1 rounded hover:bg-blue-600">
                Edit
              </a>
              <button
                onclick="openDeleteModal('<%= book._id %>')"
                class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600">
                Delete
              </button>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
  <!-- this is no found book popUp -->
  <div id="noResultsMessage" 
    class="hidden mx-auto mt-8 max-w-md text-center bg-gray-100 border border-gray-300 rounded-lg p-6 shadow-md">
    <p class="text-lg font-semibold text-gray-700 mb-4">
      ❌ No books found in stock
    </p>
    <button
      onclick="closeNoResultsMessage()"
      class="px-5 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition shadow-sm">
      Okay
    </button>
  </div>
  <!-- Delete Modal -->
   <div class="flex justify-center mt-10 gap-2">
    <%- include("../partials/pagiNation") %>
   </div>
  <%- include("../partials/deleteModal") %>
  
</body>
<script src="/js/my-books.js"></script>
<%- include("../partials/footer") %>